# PatientMatch storefront environment
#
# Copy this file to .env.local for local development. Use anon/public Supabase
# credentials only. The storefront does not require or use a Supabase
# service-role key.

# Browser-safe Supabase variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side anon Supabase variables
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Required for encrypted match-profile cookies in local builds.
# Use a random value with at least 32 characters.
PII_SECRET=replace-with-at-least-32-random-characters
